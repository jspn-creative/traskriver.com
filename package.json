{
	"name": "river-stream",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.9",
	"workspaces": ["packages/web", "packages/relay", "packages/shared"],
	"scripts": {
		"dev": "concurrently -n web,relay -c blue,magenta \"bun run --cwd packages/web dev\" \"bun run --cwd packages/relay dev:local\"",
		"dev:web": "bun run --cwd packages/web dev",
		"dev:relay": "bun run --cwd packages/relay dev:local",
		"build": "turbo run build",
		"build:relay": "bun run --cwd packages/relay build",
		"deploy": "bun run --cwd packages/web deploy",
		"preview": "bun run --cwd packages/web preview",
		"check": "turbo run check",
		"check:web": "bun run --cwd packages/web check",
		"check:relay": "bun run --cwd packages/relay check",
		"lint": "bun run --cwd packages/web lint",
		"format": "bun run --cwd packages/web format",
		"gen": "bun run --cwd packages/web gen"
	},
	"devDependencies": {
		"concurrently": "^9.1.2",
		"turbo": "^2.5.4",
		"wrangler": "^4.63.0"
	}
}
