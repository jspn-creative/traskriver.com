amends "package://github.com/jdx/hk/releases/download/v1.41.1/hk@1.41.1#/Config.pkl"

hooks {
	["pre-commit"] {
		fix = true
		steps {
			["format"] {
				glob = List(
					"*.{js,ts,tsx,json,svelte,css,md,yml,yaml}",
					"packages/**/*.{js,ts,tsx,json,svelte,css,md,yml,yaml}"
				)
				check = "bunx prettier --check {{files}}"
				fix = "bunx prettier --write {{files}}"
			}
			["check"] {
				check = "bun check"
				exclusive = true
			}
			["lint"] {
				check = "bun lint"
				exclusive = true
			}
		}
	}

	["pre-push"] {
		steps {
			["check"] {
				check = "bun check"
				exclusive = true
			}
		}
	}
}
