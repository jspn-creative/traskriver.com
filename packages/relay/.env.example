STREAM_URL=rtmps://live.cloudflare.com:443/live/<live-input-key>
RTSP_URL=rtsp://camera.local:554/stream
DEMAND_API_URL=https://your-domain.com/api/stream/demand
STATUS_API_URL=https://your-domain.com/api/relay/status
RELAY_BEARER_TOKEN=your-secret-token
# Optional tuning (defaults shown)
# POLL_INTERVAL_MS=10000
# REQUEST_TIMEOUT_MS=8000
# FAILURE_THRESHOLD=30
# LIVE_CONFIRM_MS=4000
# RELAY_HEALTH_PORT=9090   # set to 0 to disable
# RELAY_HEALTH_HOSTNAME=0.0.0.0
# With Tailscale: curl http://<machine-name>.<tailnet>.ts.net:9090/health
# RELAY_FFMPEG_VERBOSE=0   # set to 1 to log every ffmpeg stderr line (noisy)
