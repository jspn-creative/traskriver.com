{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"lib": ["ES2023"],
		"types": ["node"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "./dist",
		"rootDir": "./src",
		"noEmit": false,
		"declaration": false,
		"sourceMap": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true
	},
	"include": ["src/**/*"]
}
